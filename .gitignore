.private/
*.draft.md
*-notes.md
*-wip.md
*.temp.md

# Sensitive Data
.env
.env.*
*.key
*.pem
credentials.json
secrets/
*.secret

# IDE Settings (projekt-spezifisch)
.vscode/settings.json
.idea/workspace.xml
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Node.js (falls verwendet)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# Binary assets (use Git LFS if versioning needed)
*.png
*.jpg
*.jpeg
*.gif

